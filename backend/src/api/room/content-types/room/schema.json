{
  "kind": "collectionType",
  "collectionName": "rooms",
  "info": {
    "singularName": "room",
    "pluralName": "rooms",
    "displayName": "Room",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "description": {
      "type": "richtext"
    },
    "price": {
      "type": "integer"
    },
    "maxGuests": {
      "type": "integer"
    },
    "features": {
      "type": "text"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "reservations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::reservation.reservation",
      "mappedBy": "room"
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "isStandart": {
      "type": "boolean",
      "default": false
    },
    "isComfort": {
      "type": "boolean",
      "default": false
    },
    "isAile": {
      "type": "boolean",
      "default": false
    }
  }
}
